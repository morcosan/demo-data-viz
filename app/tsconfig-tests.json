{
  "extends": "../.config/base-tsconfig.json",
  "compilerOptions": {
    /* Build Metadata */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tests.tsbuildinfo",

    /* Language & Environment */
    "lib": ["ES2022", "DOM"],

    /* Modules & Resolution */
    "paths": {
      // ESLint doesn't detect "@app-utils/*.ts" imports
      "@app-components": ["./src/shared/components/index.ts"],
      "@app-i18n": ["./src/core/i18n/index.ts"],
      "@app-api": ["./src/core/api/index.ts"],
      "@app/*": ["./src/*"],
      "@ds/*": ["../ds/dist/*"]
    }
  },
  "include": ["tests/**/*"]
}
