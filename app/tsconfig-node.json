{
  "extends": "../.config/base-tsconfig.json",
  "compilerOptions": {
    /* Build Metadata */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    /* Language & Environment */
    "lib": ["ESNext"],
    "types": ["node"]
  },
  "include": [
    ".storybook/**/*",
    "eslint.config.ts",
    "next.config.ts",
    "package-scripts.ts",
    "scripts/**/*.ts",
    "tests/*.config.ts",
    "vitest.config.ts"
  ],
  "exclude": [".storybook/preview/**/*"]
}
