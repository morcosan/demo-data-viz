{
  "extends": "../.config/base-tsconfig.json",
  "compilerOptions": {
    /* Build Metadata */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.docs.tsbuildinfo",

    /* Language & Environment */
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Modules & Resolution */
    "paths": {
      "@ds/*": ["./dist/*"]
    }
  },
  "include": ["docs/**/*", ".storybook/preview/**/*"]
}
