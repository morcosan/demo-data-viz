    "toast": { "$value": "{z-index.lv6}" },
    "tooltip": { "$value": "{z-index.lv9}" }
  },
  "surface": {
    "page": {
      "$type": "composite",
      "$value": {
        "background-color": "{color.bg-page}"
      }
    },
    "sheet": {
      "$type": "composite",
      "$value": {
        "background-color": "{color.bg-sheet}",
        "border-radius": "{radius.md}",
        "box-shadow": "{shadow.xs}"
      }
    },
    "card": {
      "$type": "composite",
      "$value": {
        "background-color": { "$light": "{color.bg-card}", "$dark": "{color.bg-card}" },
        "border-radius": "{radius.md}",
        "box-shadow": "{shadow.xs}"
      }
    },
    "popup": {
      "$type": "composite",
      "$value": {
        "background-color": "{color.bg-popup}",
        "border-radius": "{radius.sm}",
        "box-shadow": "{shadow.sm}"
      }
    }
  }
}
